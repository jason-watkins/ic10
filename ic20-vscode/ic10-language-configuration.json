{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [],
    "autoClosingPairs": [
        {
            "open": "\"",
            "close": "\"",
            "notIn": [
                "string",
                "comment"
            ]
        },
        {
            "open": "(",
            "close": ")",
            "notIn": [
                "string",
                "comment"
            ]
        }
    ],
    "surroundingPairs": [
        {
            "open": "\"",
            "close": "\""
        },
        {
            "open": "(",
            "close": ")"
        }
    ],
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
    "indentationRules": {
        "increaseIndentPattern": "^\\s*[a-zA-Z_][a-zA-Z0-9_]*\\s*:\\s*$",
        "decreaseIndentPattern": "^$"
    }
}
