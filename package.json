{
    "name": "ic20-language",
    "displayName": "IC20 Language",
    "description": "Language support for IC20, a Rust-inspired language that compiles to IC10 assembly for Stationeers.",
    "version": "0.1.0",
    "publisher": "ic20",
    "repository": {
        "type": "git",
        "url": "https://github.com/ic20/ic20-vscode"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets",
        "Formatters"
    ],
    "icon": "icons/icon.png",
    "main": "./out/extension.js",
    "activationEvents": [],
    "contributes": {
        "configuration": {
            "title": "IC20",
            "properties": {
                "ic20.lsp.path": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the ic20-lsp binary. If empty, searches PATH for 'ic20-lsp'."
                },
                "ic20.compiler.path": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the ic20c compiler binary. If empty, searches PATH for 'ic20c'."
                }
            }
        },
        "languages": [
            {
                "id": "ic20",
                "aliases": [
                    "IC20",
                    "ic20"
                ],
                "extensions": [
                    ".ic20"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/ic20-light.svg",
                    "dark": "./icons/ic20-dark.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "ic20",
                "scopeName": "source.ic20",
                "path": "./syntaxes/ic20.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "ic20",
                "path": "./snippets/ic20.json"
            }
        ],
        "commands": [
            {
                "command": "ic20.build",
                "title": "Build IC20 File",
                "category": "IC20"
            }
        ],
        "menus": {
            "editor/title/run": [
                {
                    "command": "ic20.build",
                    "when": "resourceLangId == ic20",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "ic20.build",
                    "when": "resourceLangId == ic20",
                    "group": "ic20@1"
                }
            ]
        },
        "keybindings": [
            {
                "command": "ic20.build",
                "key": "ctrl+shift+b",
                "when": "resourceLangId == ic20 && editorFocus"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0"
    }
}
