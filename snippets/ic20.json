{
    "fn main": {
        "prefix": "fn main",
        "body": [
            "fn main() {",
            "\t$0",
            "}"
        ],
        "description": "Program entry point"
    },
    "fn": {
        "prefix": "fn",
        "body": [
            "fn ${1:name}(${2:}) -> ${3:f64} {",
            "\t$0",
            "}"
        ],
        "description": "Function declaration"
    },
    "fn void": {
        "prefix": "fnv",
        "body": [
            "fn ${1:name}(${2:}) {",
            "\t$0",
            "}"
        ],
        "description": "Void function declaration"
    },
    "device": {
        "prefix": "device",
        "body": "device ${1:name}: ${2|d0,d1,d2,d3,d4,d5,db|};",
        "description": "Device pin declaration"
    },
    "const": {
        "prefix": "const",
        "body": "const ${1:NAME}: ${2|f64,i53,bool|} = ${3:0.0};",
        "description": "Compile-time constant"
    },
    "let": {
        "prefix": "let",
        "body": "let ${1:name} = ${2:0};",
        "description": "Immutable variable binding"
    },
    "let mut": {
        "prefix": "let mut",
        "body": "let mut ${1:name} = ${2:0};",
        "description": "Mutable variable binding"
    },
    "if": {
        "prefix": "if",
        "body": [
            "if ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "If statement"
    },
    "if else": {
        "prefix": "ife",
        "body": [
            "if ${1:condition} {",
            "\t$2",
            "} else {",
            "\t$0",
            "}"
        ],
        "description": "If-else statement"
    },
    "loop": {
        "prefix": "loop",
        "body": [
            "loop {",
            "\t$0",
            "\tyield;",
            "}"
        ],
        "description": "Infinite loop with yield"
    },
    "while": {
        "prefix": "while",
        "body": [
            "while ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "While loop"
    },
    "for": {
        "prefix": "for",
        "body": [
            "for ${1:i} in ${2:0}..${3:6} {",
            "\t$0",
            "}"
        ],
        "description": "For-in range loop"
    },
    "hash": {
        "prefix": "hash",
        "body": "hash(\"${1:PrefabName}\")",
        "description": "Compile-time CRC-32 hash"
    },
    "select": {
        "prefix": "select",
        "body": "select(${1:condition}, ${2:if_true}, ${3:if_false})",
        "description": "Ternary select expression"
    },
    "batch_read": {
        "prefix": "batch_read",
        "body": "batch_read(hash(\"${1:PrefabName}\"), ${2:Field}, ${3|Average,Sum,Minimum,Maximum|})",
        "description": "Batch read from all devices of a type"
    },
    "batch_write": {
        "prefix": "batch_write",
        "body": "batch_write(hash(\"${1:PrefabName}\"), ${2:Field}, ${3:value});",
        "description": "Batch write to all devices of a type"
    },
    "main loop": {
        "prefix": "mainloop",
        "body": [
            "fn main() {",
            "\tloop {",
            "\t\t$0",
            "\t\tyield;",
            "\t}",
            "}"
        ],
        "description": "Main function with yield loop"
    },
    "program": {
        "prefix": "program",
        "body": [
            "device ${1:sensor}: ${2|d0,d1,d2,d3,d4,d5,db|};",
            "",
            "fn main() {",
            "\tloop {",
            "\t\t$0",
            "\t\tyield;",
            "\t}",
            "}"
        ],
        "description": "Full program skeleton with device and main loop"
    }
}
